# Tanren - 環境変数テンプレート
# `cp .env.example .env.local` して値を埋める
# 定義の根拠は docs/06-architecture.md 6.6.2

# ──────────────────────────────────────────
# MVP で必須
# ──────────────────────────────────────────

# --- Neon (PostgreSQL) ---
# ADR-0003. 接続文字列は ?sslmode=require を必ず付ける
DATABASE_URL=postgresql://user:pass@ep-xxxxx.aws.neon.tech/tanren?sslmode=require

# --- OpenAI ---
# ADR-0005. Usage limit を $20/月 に設定 (ダッシュボード Settings → Limits)
OPENAI_API_KEY=sk-...

# --- Passkey / WebAuthn ---
# ADR-0004. rp_id は開発時 'localhost'、本番は 'tanren.example.com'
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Tanren
WEBAUTHN_ORIGIN=http://localhost:3000

# --- セッション cookie 署名鍵 ---
# `openssl rand -hex 32` で生成、32 バイト以上
SESSION_COOKIE_SECRET=

# --- アプリ設定 ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Sentry (エラー監視、Free tier) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ──────────────────────────────────────────
# Phase 3+ で追加
# ──────────────────────────────────────────

# --- Resend (メール通知) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=tanren@example.com

# ──────────────────────────────────────────
# Phase 5+ で追加 (公開時 / 並列ユーザー発生時)
# ──────────────────────────────────────────

# --- Web Push (VAPID) ---
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=

# --- Upstash Redis (rate limit) ---
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# --- PostHog (プロダクト分析) ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
